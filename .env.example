# ═══════════════════════════════════════════════════════════════════
# IEC Launchpad — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy to `.env` (local) or set in Vercel → Settings → Environment Variables.

# ─── Database (Required) ──────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Liara, etc.)
# When empty: app runs in "no-DB" mode (marketing pages work, auth returns 503).
DATABASE_URL=

# ─── Security ─────────────────────────────────────────────────────
# Session secret (32+ char random string). Generate with:
#   openssl rand -base64 48
# Currently reserved for future use but MUST be set in production.
SESSION_SECRET=

# Allowed origin(s) for CSRF protection. Comma-separated for multi-domain.
# Dev default: http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGIN=

# ─── SMS / OTP ────────────────────────────────────────────────────
# SMS provider API key. When empty, OTP is logged to server console (dev mode).
SMS_API_KEY=

# Demo mode: when true, OTP is shown in a beautiful modal instead of SMS.
# When false, the system returns to real SMS delivery (if SMS_API_KEY is set).
DEMO_MODE=true

# ─── Email / SMTP (Free login alternative) ────────────────────────
# Email OTP login uses SMTP — FREE with Gmail App Password (500/day).
# Setup Gmail:
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password for "Mail"
#   4. Set SMTP_USER=your-email@gmail.com, SMTP_PASS=that-16-char-password
# When SMTP_HOST is empty: email OTP runs in dev mode (code shown in UI).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=IEC <your-email@gmail.com>
SMTP_FROM_NAME=مرکز کارآفرینی بین‌المللی

# ─── File Uploads ─────────────────────────────────────────────────
# Directory for uploaded receipt images.
# Vercel: /tmp/uploads (ephemeral — use S3/Cloudinary for persistent storage)
# Local dev: ./uploads
UPLOAD_DIR=./uploads

# ─── Payment ──────────────────────────────────────────────────────
# Commission rate percent (snapshot at enrollment confirmation time).
COMMISSION_RATE_PERCENT=10

# Max request body size in MB (receipt image uploads are base64-encoded).
MAX_BODY_SIZE_MB=10

# Payment info shown to students (public, no secrets).
# Accessed via process.env on the server (SSR).
VITE_PAYMENT_CARD_NUMBER=
VITE_PAYMENT_ACCOUNT_HOLDER=
